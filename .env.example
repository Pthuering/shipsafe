# ==============================================
# ShipSafe Landing Page — Umgebungsvariablen
# ==============================================
# Kopiere diese Datei als .env.local und fülle die Werte aus.

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Ohne diesen Wert wird GA4 nicht geladen (kein Fehler, nur kein Tracking)
NEXT_PUBLIC_GA_ID=

# Tally.so Form ID (für Waitlist E-Mail Capture)
# Finde die ID in deinem Tally Dashboard unter dem Formular
# Alternative: Supabase (siehe lib/components/WaitlistGate.tsx)
# NEXT_PUBLIC_TALLY_FORM_ID ist in lib/config.ts als tallyFormId gesetzt

# Optional: Supabase (wenn kein Tally verwendet wird)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
